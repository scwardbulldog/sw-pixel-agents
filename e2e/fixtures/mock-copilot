#!/usr/bin/env bash
# Mock 'copilot' executable for Pixel Agents e2e tests.
#
# Behaviour:
#   1. Parses --resume=<id> from args (optional).
#   2. Creates a new session directory with a random UUID if no --resume.
#   3. Appends an invocation record to $HOME/.copilot-mock/invocations.log.
#   4. Creates the expected events.jsonl file under $HOME/.copilot/session-state/<id>/
#   5. Writes a minimal valid JSONL line so the extension file-watcher can proceed.
#   6. Stays alive for up to 30 s (tests can kill it once assertions pass).

set -euo pipefail

SESSION_ID=""
for arg in "$@"; do
  case "$arg" in
    --resume=*)
      SESSION_ID="${arg#--resume=}"
      ;;
  esac
done

# Generate a random UUID if no session ID provided
if [ -z "$SESSION_ID" ]; then
  SESSION_ID="$(cat /proc/sys/kernel/random/uuid 2>/dev/null || uuidgen 2>/dev/null || printf '%s-%s-%s-%s-%s' "$(xxd -l 4 -p /dev/urandom)" "$(xxd -l 2 -p /dev/urandom)" "$(xxd -l 2 -p /dev/urandom)" "$(xxd -l 2 -p /dev/urandom)" "$(xxd -l 6 -p /dev/urandom)")"
fi

LOG_DIR="${HOME}/.copilot-mock"
mkdir -p "$LOG_DIR"
echo "$(date -Iseconds) session-id=${SESSION_ID} cwd=$(pwd) args=$*" >> "${LOG_DIR}/invocations.log"

SESSION_DIR="${HOME}/.copilot/session-state/${SESSION_ID}"
mkdir -p "$SESSION_DIR"
JSONL_FILE="${SESSION_DIR}/events.jsonl"

# Write session.start event
printf '{"type":"session.start","data":{"sessionId":"%s","version":1,"producer":"mock-copilot"}}\n' "$SESSION_ID" >> "$JSONL_FILE"

# Stay alive so the VS Code terminal doesn't immediately close.
sleep 30 &
SLEEP_PID=$!

# Clean exit on SIGTERM/SIGINT.
trap 'kill $SLEEP_PID 2>/dev/null; exit 0' SIGTERM SIGINT

wait $SLEEP_PID || true
